// This is your Prisma schema file for LinguaMentor
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE USER & AUTHENTICATION
// ============================================

enum UserRole {
  LEARNER
  ADMIN
  TEACHER // Future scope
}

enum CEFRLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum TargetLanguage {
  ENGLISH
  SPANISH
  FRENCH
  GERMAN
  MANDARIN
  JAPANESE
  KOREAN
  ARABIC
  PORTUGUESE
  ITALIAN
}

enum ExamType {
  IELTS
  TOEFL
  DELF
  DELE
  JLPT
  HSK
  CEFR
  OTHER
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String?  @map("first_name")
  lastName     String?  @map("last_name")
  role         UserRole @default(LEARNER)

  // Learning preferences
  targetLanguage TargetLanguage @map("target_language")
  nativeLanguage String?        @map("native_language")
  currentLevel   CEFRLevel      @default(A1) @map("current_level")
  targetExam     ExamType?      @map("target_exam")

  // Progress tracking
  readinessScore Float     @default(0) @map("readiness_score") // 0-100 exam readiness
  totalStudyTime Int       @default(0) @map("total_study_time") // in minutes
  currentStreak  Int       @default(0) @map("current_streak") // consecutive days
  longestStreak  Int       @default(0) @map("longest_streak")
  lastActiveAt   DateTime? @map("last_active_at")

  // Account management
  isActive         Boolean @default(true) @map("is_active")
  emailVerified    Boolean @default(false) @map("email_verified")
  subscriptionTier String  @default("free") @map("subscription_tier") // free, premium, enterprise

  // OAuth fields
  oauthProvider String? @map("oauth_provider")
  oauthId       String? @map("oauth_id")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  lessons                 Lesson[]
  sessions                Session[]
  assessments             Assessment[]
  aiInteractions          AIInteraction[]
  analyticsSummaries      AnalyticsSummary[]
  achievements            Achievement[]
  evaluationResults       EvaluationResult[]
  refreshTokens           RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  files                   File[]
  jobs                    Job[]

  @@index([email])
  @@index([targetLanguage])
  @@index([currentLevel])
  @@map("users")
}

// ============================================
// REFRESH TOKEN FOR SECURE AUTH
// ============================================

model RefreshToken {
  id           String   @id @default(uuid())
  tokenHash    String   @map("token_hash") // SHA-256 hashed value of the token
  expiresAt    DateTime @map("expires_at")
  revoked      Boolean  @default(false)
  replacedById String?  @map("replaced_by_id") // For token rotation tracking
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  used      Boolean  @default(false)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  used      Boolean  @default(false)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ============================================
// LESSON & CURRICULUM
// ============================================

enum SkillType {
  SPEAKING
  LISTENING
  READING
  WRITING
  GRAMMAR
  VOCABULARY
  PRONUNCIATION
}

enum LessonDifficulty {
  BEGINNER // A1-A2
  INTERMEDIATE // B1-B2
  ADVANCED // C1-C2
}

model Lesson {
  id     String @id @default(uuid())
  userId String @map("user_id")

  // Lesson metadata (AI-generated)
  title          String
  description    String?
  topic          String // e.g., "Daily Conversations", "Business English"
  skillType      SkillType        @map("skill_type")
  difficulty     LessonDifficulty
  cefrLevel      CEFRLevel        @map("cefr_level")
  targetLanguage TargetLanguage   @map("target_language")

  // AI generation context
  generatedPrompt String? @map("generated_prompt") @db.Text
  objectives      Json? // Array of learning objectives

  // Lesson content (AI-generated)
  content      Json?   @db.JsonB // Flexible structure for dialogues, exercises, etc.
  summaryNotes String? @map("summary_notes") @db.Text

  // Status
  isCompleted Boolean   @default(false) @map("is_completed")
  completedAt DateTime? @map("completed_at")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@index([userId])
  @@index([skillType])
  @@index([cefrLevel])
  @@index([isCompleted])
  @@map("lessons")
}

// ============================================
// LEARNING SESSIONS
// ============================================

enum SessionType {
  LESSON
  PRACTICE
  EXAM
  CONVERSATION
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model Session {
  id       String  @id @default(uuid())
  userId   String  @map("user_id")
  lessonId String? @map("lesson_id")

  // Session info
  sessionType SessionType   @map("session_type")
  status      SessionStatus @default(IN_PROGRESS)

  // Performance metrics
  durationMinutes Int    @default(0) @map("duration_minutes")
  accuracyScore   Float? @map("accuracy_score") // 0-100
  engagementScore Float? @map("engagement_score") // 0-100

  // AI interaction metadata
  totalInteractions Int @default(0) @map("total_interactions")
  correctAnswers    Int @default(0) @map("correct_answers")
  incorrectAnswers  Int @default(0) @map("incorrect_answers")

  // Session context (stored for continuity)
  contextData Json? @map("context_data") @db.JsonB // Redis cache key, conversation state

  // Timestamps
  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson         Lesson?         @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  aiInteractions AIInteraction[]
  feedbacks      Feedback[]

  @@index([userId])
  @@index([sessionType])
  @@index([status])
  @@index([startedAt])
  @@map("sessions")
}

// ============================================
// AI INTERACTIONS
// ============================================

enum InteractionType {
  TEXT_INPUT
  VOICE_INPUT
  AI_RESPONSE
  CORRECTION
  EXPLANATION
}

model AIInteraction {
  id        String @id @default(uuid())
  userId    String @map("user_id")
  sessionId String @map("session_id")

  // Interaction details
  interactionType InteractionType @map("interaction_type")
  userInput       String?         @map("user_input") @db.Text
  aiResponse      String?         @map("ai_response") @db.Text

  // Audio data (if voice interaction)
  audioUrl      String? @map("audio_url") // S3 URL for audio files
  transcription String? @db.Text

  // AI evaluation
  isCorrect      Boolean? @map("is_correct")
  correctionText String?  @map("correction_text") @db.Text

  // Context & metadata
  promptContext Json? @map("prompt_context") @db.JsonB
  modelMetadata Json? @map("model_metadata") @db.JsonB // model version, latency, etc.

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([interactionType])
  @@index([createdAt])
  @@map("ai_interactions")
}

// ============================================
// ASSESSMENTS & EXAMS
// ============================================

enum AssessmentType {
  PLACEMENT_TEST
  MOCK_EXAM
  QUIZ
  SKILL_CHECK
}

model Assessment {
  id     String @id @default(uuid())
  userId String @map("user_id")

  // Assessment metadata
  assessmentType AssessmentType @map("assessment_type")
  examType       ExamType?      @map("exam_type")
  skillType      SkillType?     @map("skill_type") // If skill-specific

  // Scoring
  totalScore      Float     @map("total_score")
  maxScore        Float     @map("max_score")
  percentageScore Float     @map("percentage_score")
  cefrLevel       CEFRLevel @map("cefr_level")

  // Breakdown by skill
  readingScore   Float? @map("reading_score")
  writingScore   Float? @map("writing_score")
  speakingScore  Float? @map("speaking_score")
  listeningScore Float? @map("listening_score")

  // AI feedback
  overallFeedback String? @map("overall_feedback") @db.Text
  strengths       Json?   @db.JsonB // Array of strings
  weaknesses      Json?   @db.JsonB // Array of strings
  recommendations Json?   @db.JsonB // Array of strings

  // Exam details
  durationMinutes Int?     @map("duration_minutes")
  isPassed        Boolean? @map("is_passed")

  // Timestamps
  completedAt DateTime @default(now()) @map("completed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluationResults EvaluationResult[]
  feedbacks         Feedback[]

  @@index([userId])
  @@index([assessmentType])
  @@index([examType])
  @@index([completedAt])
  @@map("assessments")
}

// ============================================
// EVALUATION RESULTS
// ============================================

enum EvaluationCategory {
  GRAMMAR
  VOCABULARY
  PRONUNCIATION
  FLUENCY
  COHERENCE
  TASK_ACHIEVEMENT
  LEXICAL_RESOURCE
  GRAMMATICAL_RANGE
}

model EvaluationResult {
  id           String  @id @default(uuid())
  userId       String  @map("user_id")
  assessmentId String? @map("assessment_id")

  // Evaluation metadata
  skillType SkillType          @map("skill_type")
  category  EvaluationCategory

  // Scoring
  score      Float
  maxScore   Float   @map("max_score")
  rubricUsed String? @map("rubric_used") // e.g., "IELTS Writing Band Descriptor"

  // AI analysis
  detailedFeedback String? @map("detailed_feedback") @db.Text
  errorExamples    Json?   @map("error_examples") @db.JsonB
  improvementTips  Json?   @map("improvement_tips") @db.JsonB

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessment Assessment? @relation(fields: [assessmentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([assessmentId])
  @@index([skillType])
  @@index([category])
  @@map("evaluation_results")
}

// ============================================
// FEEDBACK
// ============================================

enum FeedbackType {
  GRAMMAR_CORRECTION
  PRONUNCIATION_TIP
  VOCABULARY_SUGGESTION
  FLUENCY_ADVICE
  GENERAL_COMMENT
}

model Feedback {
  id           String  @id @default(uuid())
  sessionId    String? @map("session_id")
  assessmentId String? @map("assessment_id")

  // Feedback details
  feedbackType FeedbackType        @map("feedback_type")
  category     EvaluationCategory?

  // Content
  originalText  String? @map("original_text") @db.Text
  correctedText String? @map("corrected_text") @db.Text
  explanation   String  @db.Text

  // Metadata
  severity    String? // "low", "medium", "high"
  isAddressed Boolean @default(false) @map("is_addressed")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  session    Session?    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  assessment Assessment? @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([assessmentId])
  @@index([feedbackType])
  @@index([isAddressed])
  @@map("feedbacks")
}

// ============================================
// ANALYTICS & PROGRESS TRACKING
// ============================================

enum AnalyticsPeriod {
  DAILY
  WEEKLY
  MONTHLY
  ALL_TIME
}

model AnalyticsSummary {
  id     String @id @default(uuid())
  userId String @map("user_id")

  // Period
  period      AnalyticsPeriod
  periodStart DateTime        @map("period_start")
  periodEnd   DateTime        @map("period_end")

  // Activity metrics
  totalSessions    Int @default(0) @map("total_sessions")
  totalStudyTime   Int @default(0) @map("total_study_time") // minutes
  lessonsCompleted Int @default(0) @map("lessons_completed")
  assessmentsTaken Int @default(0) @map("assessments_taken")

  // Performance metrics
  averageAccuracy Float?  @map("average_accuracy")
  currentStreak   Int     @default(0) @map("current_streak")
  cefrProgress    String? @map("cefr_progress") // e.g., "A2 -> B1"
  readinessScore  Float?  @map("readiness_score")

  // Skill breakdown
  speakingScore  Float? @map("speaking_score")
  listeningScore Float? @map("listening_score")
  readingScore   Float? @map("reading_score")
  writingScore   Float? @map("writing_score")

  // Weaknesses & strengths
  weakAreas   Json? @map("weak_areas") @db.JsonB // Array of skill areas
  strongAreas Json? @map("strong_areas") @db.JsonB

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period, periodStart])
  @@index([userId])
  @@index([period])
  @@index([periodStart])
  @@map("analytics_summaries")
}

// ============================================
// GAMIFICATION & ACHIEVEMENTS
// ============================================

enum AchievementCategory {
  STREAK
  SKILL_MASTERY
  EXAM_SUCCESS
  MILESTONE
  CONSISTENCY
}

model Achievement {
  id     String @id @default(uuid())
  userId String @map("user_id")

  // Achievement details
  name        String
  description String?
  category    AchievementCategory
  iconUrl     String?             @map("icon_url")

  // Progress
  currentProgress Int     @default(0) @map("current_progress")
  targetProgress  Int     @map("target_progress")
  isUnlocked      Boolean @default(false) @map("is_unlocked")

  // Rewards
  xpReward   Int?    @map("xp_reward")
  badgeLevel String? @map("badge_level") // bronze, silver, gold

  // Timestamps
  unlockedAt DateTime? @map("unlocked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@index([isUnlocked])
  @@map("achievements")
}

// ============================================
// AI MODEL TRACKING & AUDIT
// ============================================

enum ModelProvider {
  OPENAI
  ANTHROPIC
  GOOGLE
  WHISPER
  ELEVENLABS
  CUSTOM
}

model AIModelRun {
  id String @id @default(uuid())

  // Model metadata
  modelProvider ModelProvider @map("model_provider")
  modelName     String        @map("model_name")
  modelVersion  String?       @map("model_version")

  // Request details
  endpoint       String
  promptHash     String? @map("prompt_hash") // SHA-256 hash for privacy
  requestPayload Json?   @map("request_payload") @db.JsonB

  // Response details
  responseHash     String? @map("response_hash")
  responseMetadata Json?   @map("response_metadata") @db.JsonB

  // Performance
  latencyMs     Int?   @map("latency_ms")
  tokenCount    Int?   @map("token_count")
  estimatedCost Float? @map("estimated_cost")

  // Status
  isSuccess    Boolean @default(true) @map("is_success")
  errorMessage String? @map("error_message") @db.Text

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")

  @@index([modelProvider])
  @@index([modelName])
  @@index([isSuccess])
  @@index([createdAt])
  @@map("ai_model_runs")
}

// ============================================
// ADMIN & SYSTEM LOGS
// ============================================

enum LogLevel {
  INFO
  WARNING
  ERROR
  CRITICAL
}

model AdminLog {
  id String @id @default(uuid())

  // Log details
  logLevel LogLevel @map("log_level")
  message  String   @db.Text
  category String // "auth", "payment", "ai", "system"

  // Context
  userId    String? @map("user_id")
  sessionId String? @map("session_id")
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  // Additional data
  metadata   Json?   @db.JsonB
  stackTrace String? @map("stack_trace") @db.Text

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")

  @@index([logLevel])
  @@index([category])
  @@index([userId])
  @@index([createdAt])
  @@map("admin_logs")
}

// ============================================
// FILE MANAGEMENT
// ============================================

enum FileStatus {
  PENDING
  UPLOADED
  PROCESSING
  PROCESSED
  FAILED
  DELETED
}

enum FileType {
  AUDIO
  VIDEO
  IMAGE
  DOCUMENT
  OTHER
}

model File {
  id String @id @default(uuid())
  userId String @map("user_id")

  // File metadata
  originalName String @map("original_name")
  fileName     String @map("file_name") // S3 key
  mimeType     String @map("mime_type")
  size         BigInt
  fileType     FileType @map("file_type")
  
  // Status and processing
  status        FileStatus @default(PENDING)
  checksum      String? // SHA-256 hash
  metadata      Json?   @db.JsonB // additional metadata like duration, resolution, etc.
  
  // S3 information
  s3Bucket String @map("s3_bucket")
  s3Key    String @map("s3_key")
  s3Url    String? @map("s3_url") // Public URL if applicable
  
  // Processing results
  processedUrl   String? @map("processed_url")
  processedAt    DateTime? @map("processed_at")
  errorMessage   String? @map("error_message") @db.Text
  processingTime Int?    @map("processing_time") // in milliseconds
  
  // TTL for cleanup
  expiresAt DateTime? @map("expires_at")
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalJobs Job[] @relation("JobOriginalFile")
  outputJobs   Job[] @relation("JobOutputFile")
  
  @@index([userId])
  @@index([status])
  @@index([fileType])
  @@index([createdAt])
  @@index([expiresAt])
  @@map("files")
}

// ============================================
// JOB QUEUE SYSTEM
// ============================================

enum JobStatus {
  PENDING
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  TIMEOUT
}

enum JobType {
  AUDIO_TRANSCRIPTION
  VIDEO_ANALYSIS
  AI_PROCESSING
  FILE_CONVERSION
  CONTENT_GENERATION
  ASSESSMENT_SCORING
}

enum JobPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Job {
  id String @id @default(uuid())
  userId String @map("user_id")
  fileId String? @map("file_id")
  
  // Job configuration
  jobType   JobType   @map("job_type")
  priority  JobPriority @default(NORMAL)
  status    JobStatus @default(PENDING)
  
  // Job data
  payload Json @db.JsonB // Job-specific data
  result  Json? @db.JsonB // Job results
  metadata Json? @db.JsonB // optional metadata
  
  // Processing details
  queueName    String @map("queue_name")
  queueJobId   String? @map("queue_job_id")
  workerId     String? @map("worker_id") // Which worker processed this job
  attempts     Int @default(0)
  maxAttempts  Int @default(3) @map("max_attempts")
  
  // Timing
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  failedAt    DateTime? @map("failed_at")
  timeoutAt   DateTime? @map("timeout_at")
  cancelledAt DateTime? @map("cancelled_at")
  
  // Error handling
  errorMessage String? @map("error_message") @db.Text
  error        String? @db.Text
  errorStack   String? @map("error_stack") @db.Text
  
  // Callbacks and webhooks
  callbackUrl String? @map("callback_url")
  internalToken String? @map("internal_token") // INTERNAL_SERVICE_TOKEN
  
  // Progress tracking
  progress Int @default(0) // 0-100
  progressMessage String? @map("progress_message")
  outputFileId String? @map("output_file_id")
  outputFile   File?   @relation("JobOutputFile", fields: [outputFileId], references: [id], onDelete: SetNull)
  
  // TTL for cleanup
  expiresAt DateTime? @map("expires_at")
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  file File? @relation("JobOriginalFile", fields: [fileId], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([fileId])
  @@index([jobType])
  @@index([status])
  @@index([priority])
  @@index([queueName])
  @@index([createdAt])
  @@index([expiresAt])
  @@index([status, createdAt])
  @@map("jobs")
}
