# Database
DATABASE_URL=postgresql://linguamentor_user:securepass@db:5432/linguamentor_db?schema=public

# JWT Configuration
JWT_ACCESS_SECRET=replace_with_strong_random_access_secret
JWT_REFRESH_SECRET=replace_with_strong_random_refresh_secret
JWT_ISSUER="lingumentor-api"
JWT_AUDIENCE="lingumentor-users"
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Bcrypt Configuration
BCRYPT_SALT_ROUNDS=12

# CORS Configuration
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Server Configuration
PORT=4000
NODE_ENV=development
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# OAuth Configuration (Optional - for future implementation)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# Email Configuration (Optional - for email verification)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM=""

# Redis Configuration (Optional - for caching)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""