# Database
DATABASE_URL=postgresql://linguamentor_user:securepass@db:5432/linguamentor_db?schema=public

# JWT Configuration
JWT_ACCESS_SECRET=replace_with_strong_random_access_secret
JWT_REFRESH_SECRET=replace_with_strong_random_refresh_secret
JWT_ISSUER="lingumentor-api"
JWT_AUDIENCE="lingumentor-users"
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Bcrypt Configuration
BCRYPT_SALT_ROUNDS=12

# CORS Configuration
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Server Configuration
PORT=4000
NODE_ENV=development
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# OAuth Configuration (Optional - for future implementation)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# Email Configuration (Optional - for email verification)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM=""

# Redis Configuration (Optional - for caching)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_URL="redis://localhost:6379"

# AWS S3 Configuration
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET="lingumentor-files"
S3_ENDPOINT="" # Optional: for S3-compatible services like MinIO

# File Upload Configuration
MAX_FILE_SIZE=104857600 # 100MB in bytes
ALLOWED_MIME_TYPES="audio/*,video/*,image/*,application/pdf,text/*"
PRESIGNED_URL_EXPIRY=3600 # 1 hour in seconds

# Internal Service Configuration
INTERNAL_SERVICE_TOKEN="your-secure-internal-service-token"
WEBHOOK_SECRET="optional-hmac-secret-for-webhook-signatures"
AI_QUEUE_NAME="ai-jobs"

# Job Queue Configuration
JOB_TIMEOUT=300000 # 5 minutes in milliseconds
JOB_MAX_ATTEMPTS=3
QUEUE_CLEANUP_INTERVAL=3600000 # 1 hour in milliseconds
