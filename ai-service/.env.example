# LinguaMentor AI Service - Environment Example

# Core
SERVICE_NAME=ai-service
LOG_LEVEL=info

# Worker control
WORKER_CONCURRENCY=4
# Set to true to disable starting the Redis worker (API-only mode)
DISABLE_WORKER=false

# Redis
# Use the compose service name 'redis' by default
REDIS_URL=redis://redis:6379/0
REDIS_QUEUE_NAME=ai-jobs

# Backend callbacks
# Point to your backend internal base URL
BACKEND_URL=http://backend:4000
# Shared secret for internal webhook auth (replace in deployment)
INTERNAL_SERVICE_TOKEN=replace-with-internal-secret
# Optional HMAC secret used to sign webhook payloads
WEBHOOK_SECRET=replace-with-webhook-secret

# AI Providers
# Choose one: openai|anthropic|deepseek|azure
MODEL_PROVIDER=openai
OPENAI_API_KEY=replace-with-openai-key
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# ASR Providers
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=

# TTS Providers
AZURE_TTS_KEY=
AZURE_TTS_REGION=
ELEVENLABS_API_KEY=

# Safety & limits
MAX_PROMPT_CHARS=8000
MAX_TEXT_CHARS=20000
ENABLE_PROMPT_INJECTION_CHECKS=true

# HTTP clients
HTTP_TIMEOUT_SECONDS=30
MAX_RETRIES=3
