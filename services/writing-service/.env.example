LM_APP_ENV=development
LM_APP_DEBUG=true
LM_APP_PORT=8001
LM_USE_MOCK_PROVIDER=false

LM_DB_HOST=127.0.0.1
LM_DB_PORT=5432
LM_DB_NAME=linguamentor
LM_DB_USER=
LM_DB_PASSWORD=

LM_REDIS_URL=redis://127.0.0.1:6379

# AI Providers — fill in the key for the provider you're using
LM_GROQ_API_KEY=
LM_OPENAI_API_KEY=
LM_GEMINI_API_KEY=
LM_ANTHROPIC_API_KEY=

# Calibration
LM_CALIBRATION_VERSION=v1.0-dev

# JWT — paths to PEM files generated by scripts/generate_jwt_keys.py
LM_JWT_PRIVATE_KEY_PATH=../../secrets/jwt_private.pem
LM_JWT_PUBLIC_KEY_PATH=../../secrets/jwt_public.pem
LM_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
LM_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
