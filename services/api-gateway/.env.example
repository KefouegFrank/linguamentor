# API Gateway Environment Configuration

LM_APP_ENV=development
LM_APP_PORT=3000

# JWT
LM_JWT_PUBLIC_KEY_PATH=../../secrets/jwt_public.pem

# Frontend URL — used for CORS origin in production
LM_FRONTEND_URL=https:

# Redis — same instance as writing-service
LM_REDIS_URL=redis://localhost:6379

# Service URLs (internal — point to docker-compose service names in production)
LM_WRITING_SERVICE_URL=http://localhost:8001
LM_VOICE_SERVICE_URL=http://localhost:8002
LM_ADAPTIVE_ENGINE_URL=http://localhost:8003
LM_READINESS_ENGINE_URL=http://localhost:8004

# Rate limiting
LM_RATE_LIMIT_MAX=200
LM_RATE_LIMIT_WINDOW_MS=60000


