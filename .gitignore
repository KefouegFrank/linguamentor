# -------------------------------------------
# SECRETS 
# -------------------------------------------
.env
.env.*
!.env.example          # .env.example IS committed — it's the contract

# JWT key pair for local dev (generated in P3)
secrets/
*.pem
*.key
*.p12
*.pfx


# -------------------------------------------
# PYTHON
# -------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
.eggs/
dist/
build/
wheels/

# Virtual environments — each service has its own
.venv/
venv/
env/
ENV/

# Test & coverage artifacts
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.pytest_cache

# Type checker
.mypy_cache/
.dmypy.json
dmypy.json

# Linter cache
.ruff_cache/

# Alembic — versions ARE committed, runtime files are not
# alembic/versions/ ← intentionally NOT ignored
*.pyc                  # already covered above, belt-and-suspenders


# -------------------------------------------
# NODE.JS / TYPESCRIPT
# -------------------------------------------
node_modules/
dist/
build/
.next/
.nuxt/
out/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# TypeScript compiled output
*.js.map
*.d.ts.map


# -------------------------------------------
# DOCKER
# -------------------------------------------
# docker-compose.yml IS committed
# But local override files are not
docker-compose.override.yml
docker-compose.local.yml


# -------------------------------------------
# TESTING ARTIFACTS
# -------------------------------------------
# Temporary debug scripts (like debug_pg.py from F7)
scripts/debug_*.py
scripts/test_*.py
# Exception: test_connections.py is a real utility — keep it
!scripts/test_connections.py


# -------------------------------------------
# DATA & AUDIO FILES
# -------------------------------------------
# WER audio samples — binary files, not source code
data/
*.mp3
*.wav
*.ogg
*.m4a
*.flac


# -------------------------------------------
# OPERATING SYSTEM
# -------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini


# -------------------------------------------
# IDE & EDITORS
# -------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.swn
*.orig
*.bak
*~


# -------------------------------------------
# KUBERNETES & HELM (local generated files)
# -------------------------------------------
# Helm rendered manifests (generated, not source)
*.rendered.yaml
charts/*.tgz


# -------------------------------------------
# LOGS
# -------------------------------------------
*.log
logs/
